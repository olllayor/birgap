generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum OtpStatus {
  UNUSED
  USED
  EXPIRED
}

enum SmsProvider {
  SAYQAL
  MOCK
}

enum SmsType {
  OTP
}

enum DevicePlatform {
  ANDROID
  IOS
  WEB
}

enum PushPlatform {
  FCM
  APNS
  HMS
}

enum EnvelopeStatus {
  PENDING
  DELIVERED
  READ
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
}

enum UploadStatus {
  PENDING
  COMPLETE
  FAILED
}

model User {
  id          String     @id @default(uuid()) @db.Uuid
  phoneHash   String     @unique
  phoneMasked String?
  status      UserStatus @default(ACTIVE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  username          String?     @unique
  profileAvatarUrl  String?
  encryptedProfile  Json?
  profileKeyHash    String?

  devices         Device[]
  refreshTokens   RefreshToken[]
  sentMessages    Message[]        @relation("SentMessages")
  threadsAsUserA  DirectThread[]   @relation("ThreadUserA")
  threadsAsUserB  DirectThread[]   @relation("ThreadUserB")
  backups         BackupBlob[]
  groupMembers    GroupMember[]
  reactions       MessageReaction[]
  media           MessageMedia[]
}

model Device {
  id                String         @id @default(uuid()) @db.Uuid
  userId            String         @db.Uuid
  platform          DevicePlatform
  displayName       String?
  identityPublicKey String
  pushToken         String?
  pushPlatform      PushPlatform?
  pushActive        Boolean        @default(false)
  active            Boolean        @default(true)
  lastSeenAt        DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  signedPrekeys     SignedPrekey[]
  oneTimePrekeys    OneTimePrekey[]
  sentMessages      Message[]        @relation("SenderDeviceMessages")
  receivedEnvelopes MessageEnvelope[] @relation("RecipientDeviceEnvelopes")
  socketTickets     SocketTicket[]

  @@index([userId, active])
}

model SignedPrekey {
  id        String   @id @default(uuid()) @db.Uuid
  deviceId  String   @db.Uuid
  keyId     Int
  publicKey String
  signature String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, active])
  @@unique([deviceId, keyId])
}

model OneTimePrekey {
  id         String    @id @default(uuid()) @db.Uuid
  deviceId   String    @db.Uuid
  keyId      Int
  publicKey  String
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([deviceId, keyId])
  @@index([deviceId, consumedAt])
}

model DirectThread {
  id             String   @id @default(uuid()) @db.Uuid
  userAId        String   @db.Uuid
  userBId        String   @db.Uuid
  latestSequence Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userA    User      @relation("ThreadUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB    User      @relation("ThreadUserB", fields: [userBId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([userAId, userBId])
}

model Message {
  id                   String    @id @default(uuid()) @db.Uuid
  threadId             String?   @db.Uuid
  groupId              String?   @db.Uuid
  senderUserId         String    @db.Uuid
  senderDeviceId       String    @db.Uuid
  idempotencyKey       String
  threadSequence       Int
  replyToMessageId     String?   @db.Uuid
  createdAt            DateTime  @default(now())
  deletedAt            DateTime?
  editedAt             DateTime?
  lastEditIdempotencyKey String?

  thread       DirectThread?    @relation(fields: [threadId], references: [id], onDelete: Cascade)
  group        Group?           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender       User             @relation("SentMessages", fields: [senderUserId], references: [id], onDelete: Cascade)
  senderDevice Device           @relation("SenderDeviceMessages", fields: [senderDeviceId], references: [id], onDelete: Restrict)
  replyTo      Message?         @relation("MessageReplies", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies      Message[]        @relation("MessageReplies")
  envelopes    MessageEnvelope[]
  reactions    MessageReaction[]
  adminDeletes MessageAdminDeleteLog[]
  media        MessageMedia[]

  @@unique([senderDeviceId, idempotencyKey])
  @@unique([threadId, threadSequence])
  @@unique([groupId, threadSequence])
  @@index([threadId, threadSequence])
  @@index([groupId, threadSequence])
  @@index([replyToMessageId])
}

model MessageMedia {
  id                      String       @id @default(uuid()) @db.Uuid
  userId                  String       @db.Uuid
  messageId               String?      @db.Uuid
  mediaType               MediaType
  bucketKey               String       @unique
  mimeType                String
  sizeBytes               Int
  filename                String
  thumbnailBucketKey      String?
  width                   Int?
  height                  Int?
  duration                Int?
  mediaCiphertextHash     String
  thumbnailCiphertextHash String?
  uploadStatus            UploadStatus @default(PENDING)
  uploadedAt              DateTime?
  uploadSessionId         String?      @unique @db.Uuid
  createdAt               DateTime     @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message Message? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([userId, uploadStatus])
  @@index([messageId])
  @@index([bucketKey])
  @@index([uploadStatus, createdAt])
}

model MessageEnvelope {
  id                String         @id @default(uuid()) @db.Uuid
  messageId         String         @db.Uuid
  recipientUserId   String         @db.Uuid
  recipientDeviceId String         @db.Uuid
  ciphertext        Json
  status            EnvelopeStatus @default(PENDING)
  deliveredAt       DateTime?
  readAt            DateTime?
  envelopeSequence  BigInt         @default(autoincrement())
  envelopeVersion   Int            @default(1)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  message         Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  recipientDevice Device  @relation("RecipientDeviceEnvelopes", fields: [recipientDeviceId], references: [id], onDelete: Restrict)

  @@unique([messageId, recipientDeviceId])
  @@index([recipientDeviceId, status, envelopeSequence])
  @@index([recipientDeviceId, updatedAt])
  @@index([recipientUserId, status])
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
}

model SocketTicket {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  deviceId    String    @db.Uuid
  sessionId   String    @db.Uuid
  tokenHash   String    @unique
  expiresAt   DateTime
  consumedAt  DateTime?
  consumedBy  String?
  createdAt   DateTime  @default(now())

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([userId, deviceId, expiresAt])
}

model BackupBlob {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @unique @db.Uuid
  bucketKey  String
  sha256     String
  sizeBytes  Int
  version    Int
  uploadedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Otp {
  id        String    @id @default(uuid()) @db.Uuid
  phoneHash String
  code      String
  status    OtpStatus @default(UNUSED)
  attempts  Int       @default(0)
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([phoneHash, status, expiresAt])
  @@index([phoneHash, status, createdAt])
}

model SmsReport {
  id        String       @id @default(uuid()) @db.Uuid
  phoneHash String
  type      SmsType
  provider  SmsProvider
  success   Boolean
  error     String?
  createdAt DateTime     @default(now())

  @@index([phoneHash, createdAt])
}

model Group {
  id                 String         @id @default(uuid()) @db.Uuid
  encryptedMetadata  Json           // Encrypted Group Name & Photo
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  members            GroupMember[]
  messages           Message[]
}

model GroupMember {
  groupId   String   @db.Uuid
  userId    String   @db.Uuid
  role      String   @default("MEMBER") // ADMIN, MEMBER
  joinedAt  DateTime @default(now())

  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@index([userId])
}

model UnreadCounter {
  userId     String   @db.Uuid
  threadType String
  threadId   String   @db.Uuid
  count      Int      @default(0)
  updatedAt  DateTime @updatedAt

  @@id([userId, threadType, threadId])
  @@index([userId])
}

model HiddenMessage {
  userId    String   @db.Uuid
  messageId String   @db.Uuid
  createdAt DateTime @default(now())

  @@id([userId, messageId])
}

model MessageAdminDeleteLog {
  id          String   @id @default(uuid()) @db.Uuid
  messageId   String   @db.Uuid
  adminUserId String   @db.Uuid
  deletedAt   DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([adminUserId])
}

model MessageReaction {
  id        String   @id @default(uuid()) @db.Uuid
  messageId String   @db.Uuid
  userId    String   @db.Uuid
  emoji     String   @db.VarChar(16)
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, messageId])
  @@index([messageId])
}
