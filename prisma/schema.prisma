generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum ReportReason {
  SPAM
  HARASSMENT
  HATE_SPEECH
  SEXUAL_CONTENT
  VIOLENCE
  IMPERSONATION
  OTHER
}

enum ReportStatus {
  OPEN
  IN_REVIEW
  CLOSED
}

enum ReportResolution {
  DISMISSED
  AUTO_CLOSED_TOMBSTONED
  AUTO_CLOSED_SUSPENDED
}

enum AdminAuditAction {
  MESSAGE_TOMBSTONE
  MESSAGE_UNTOMBSTONE
  USER_SUSPEND
  USER_UNSUSPEND
  REPORT_DISMISS
  REPORT_REVIEW_START
  ROLE_PROMOTE
  ROLE_DEMOTE
  METRICS_ROLLUP
  STRIKE_RESET
}

enum AdminAuditTargetType {
  MESSAGE
  USER
  REPORT
}

enum DailyMetricKind {
  MESSAGES_SENT_DIRECT
  MESSAGES_SENT_GROUP
  DAU
  NEW_USERS
  REPORTS_OPENED
  REPORTS_RESOLVED
  USERS_SUSPENDED
}

enum OtpStatus {
  UNUSED
  USED
  EXPIRED
}

enum SmsProvider {
  SAYQAL
  MOCK
}

enum SmsType {
  OTP
}

enum DevicePlatform {
  ANDROID
  IOS
  WEB
  MACOS
  WINDOWS
  LINUX
}

enum PushPlatform {
  FCM
  APNS
  HMS
}

enum EnvelopeStatus {
  PENDING
  DELIVERED
  READ
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
}

enum UploadStatus {
  PENDING
  COMPLETE
  FAILED
}

enum MessageContentType {
  TEXT
  LOCATION
  VENUE
}

enum CallType {
  AUDIO
  VIDEO
}

// Call lifecycle: RINGING -> ACTIVE -> ENDED, or RINGING -> DECLINED (callee
// rejected) / MISSED (ring timeout or caller cancel) / FAILED (signaling or
// media setup error). Terminal rows are what GET /calls paginates over.
enum CallStatus {
  RINGING
  ACTIVE
  ENDED
  MISSED
  DECLINED
  FAILED
}

model User {
  id          String     @id @default(uuid()) @db.Uuid
  phoneHash   String     @unique
  phoneMasked String?
  status      UserStatus @default(ACTIVE)
  role        UserRole   @default(USER)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  username          String?     @unique
  usernameChangedAt DateTime?
  profileAvatarUrl  String?
  encryptedProfile  Json?
  profileKeyHash    String?
  strikeCount       Int         @default(0)
  lastStrikeAt      DateTime?

  devices          Device[]
  refreshTokens    RefreshToken[]
  sentMessages     Message[]        @relation("SentMessages")
  threadsAsUserA   DirectThread[]   @relation("ThreadUserA")
  threadsAsUserB   DirectThread[]   @relation("ThreadUserB")
  backups          BackupBlob[]
  groupMembers     GroupMember[]
  reactions        MessageReaction[]
  media            MessageMedia[]
  receivedEnvelopes MessageEnvelope[] @relation("RecipientUserEnvelopes")
  hiddenMessages   HiddenMessage[]
  unreadCounters   UnreadCounter[]
  pinnedMessages   PinnedMessage[]
  filedReports    Report[]         @relation("ReportFiler")
  suspensionsAsTarget  UserSuspension[] @relation("SuspensionTarget")
  suspensionsAsActor   UserSuspension[] @relation("SuspensionActor")
  suspensionsAsRevoker UserSuspension[] @relation("SuspensionRevoker")
  blocksMade       UserBlock[]     @relation("Blocker")
  blocksReceived   UserBlock[]     @relation("Blocked")
  threadSettings   ThreadSetting[]
  callsMade        CallLog[]       @relation("CallsMade")
  callsReceived    CallLog[]       @relation("CallsReceived")
  contacts         Contact[]       @relation("OwnedContacts")
  contactOf        Contact[]       @relation("ContactTarget")
  folders          Folder[]

  @@index([role])
  @@index([username])
}

// Telegram-style user blocking. A row means blocker no longer wants contact
// from blocked: direct sends are rejected, typing indicators are dropped, and
// presence is hidden from the blocked user. Enforcement is app-level (messages
// service, users service, realtime gateway).
model UserBlock {
  id        String   @id @default(uuid()) @db.Uuid
  blockerId String   @db.Uuid
  blockedId String   @db.Uuid
  createdAt DateTime @default(now())

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

model Device {
  id                String         @id @default(uuid()) @db.Uuid
  userId            String         @db.Uuid
  platform          DevicePlatform
  displayName       String?
  identityPublicKey String
  pushToken         String?
  pushPlatform      PushPlatform?
  pushActive        Boolean        @default(false)
  active            Boolean        @default(true)
  lastSeenAt        DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  signedPrekeys     SignedPrekey[]
  oneTimePrekeys    OneTimePrekey[]
  sentMessages      Message[]        @relation("SenderDeviceMessages")
  receivedEnvelopes MessageEnvelope[] @relation("RecipientDeviceEnvelopes")
  socketTickets     SocketTicket[]

  @@index([userId, active])
}

model SignedPrekey {
  id        String   @id @default(uuid()) @db.Uuid
  deviceId  String   @db.Uuid
  keyId     Int
  publicKey String
  signature String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, active])
  @@unique([deviceId, keyId])
}

model OneTimePrekey {
  id         String    @id @default(uuid()) @db.Uuid
  deviceId   String    @db.Uuid
  keyId      Int
  publicKey  String
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([deviceId, keyId])
  @@index([deviceId, consumedAt])
}

model DirectThread {
  id             String   @id @default(uuid()) @db.Uuid
  userAId        String   @db.Uuid
  userBId        String   @db.Uuid
  latestSequence Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userA    User            @relation("ThreadUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB    User            @relation("ThreadUserB", fields: [userBId], references: [id], onDelete: Cascade)
  messages Message[]
  settings ThreadSetting[]

  @@unique([userAId, userBId])
}

// Per-user, per-direct-thread settings (currently just mute). A mutedUntil in
// the future suppresses FCM push wakeups for that user's devices on new
// messages in the thread; socket delivery and unread counting are unaffected.
// "Muted forever" is stored as a far-future timestamp (9999-12-31), which
// leaves room for timed mutes later without a schema change.
model ThreadSetting {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  threadId   String    @db.Uuid
  mutedUntil DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread DirectThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([userId, threadId])
  @@index([threadId])
}

model Message {
  id                   String             @id @default(uuid()) @db.Uuid
  threadId             String?            @db.Uuid
  groupId              String?            @db.Uuid
  senderUserId         String             @db.Uuid
  senderDeviceId       String             @db.Uuid
  idempotencyKey       String
  threadSequence       Int
  contentType          MessageContentType @default(TEXT)
  replyToMessageId     String?            @db.Uuid
  forwarded            Boolean            @default(false)
  createdAt            DateTime           @default(now())
  deletedAt            DateTime?
  editedAt             DateTime?
  lastEditIdempotencyKey String?
  // Set exactly once when group fan-out has broadcast this message. Used as an
  // idempotency marker so a retried fan-out job does not re-emit realtime/push.
  fannedOutAt          DateTime?

  thread       DirectThread?    @relation(fields: [threadId], references: [id], onDelete: Cascade)
  group        Group?           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender       User             @relation("SentMessages", fields: [senderUserId], references: [id], onDelete: Cascade)
  // Cascade (was Restrict): a device is only hard-deleted when its owner is
  // deleted, and a device's sent messages belong to that same owner — so they are
  // already being removed. Restrict here made User deletion impossible.
  senderDevice Device           @relation("SenderDeviceMessages", fields: [senderDeviceId], references: [id], onDelete: Cascade)
  replyTo      Message?         @relation("MessageReplies", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies      Message[]        @relation("MessageReplies")
  envelopes    MessageEnvelope[]
  reactions    MessageReaction[]
  reports      Report[]
  media        MessageMedia[]
  hiddenBy     HiddenMessage[]
  pins         PinnedMessage[]

  @@unique([senderDeviceId, idempotencyKey])
  @@unique([threadId, threadSequence])
  @@unique([groupId, threadSequence])
  @@index([replyToMessageId])
}

model MessageMedia {
  id                      String       @id @default(uuid()) @db.Uuid
  userId                  String       @db.Uuid
  messageId               String?      @db.Uuid
  mediaType               MediaType
  bucketKey               String
  mimeType                String
  sizeBytes               Int
  filename                String
  thumbnailBucketKey      String?
  width                   Int?
  height                  Int?
  duration                Int?
  mediaCiphertextHash     String
  thumbnailCiphertextHash String?
  uploadStatus            UploadStatus @default(PENDING)
  uploadedAt              DateTime?
  uploadSessionId         String?      @unique @db.Uuid
  createdAt               DateTime     @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message Message? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([userId, uploadStatus])
  @@index([messageId])
  @@index([bucketKey])
  @@index([uploadStatus, createdAt])
}

model MessageEnvelope {
  id                String         @id @default(uuid()) @db.Uuid
  messageId         String         @db.Uuid
  recipientUserId   String         @db.Uuid
  recipientDeviceId String         @db.Uuid
  ciphertext        Json
  status            EnvelopeStatus @default(PENDING)
  deliveredAt       DateTime?
  readAt            DateTime?
  envelopeSequence  BigInt         @default(autoincrement())
  envelopeVersion   Int            @default(1)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  message         Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  // Cascade (was Restrict): deleting a device removes that device's inbox copies.
  // Restrict blocked User deletion because a user's device is the recipient of
  // envelopes belonging to other users' (non-deleted) messages.
  recipientDevice Device  @relation("RecipientDeviceEnvelopes", fields: [recipientDeviceId], references: [id], onDelete: Cascade)
  // Referential integrity for the recipient user (previously a bare column).
  recipientUser   User    @relation("RecipientUserEnvelopes", fields: [recipientUserId], references: [id], onDelete: Cascade)

  @@unique([messageId, recipientDeviceId])
  @@index([recipientDeviceId, status, envelopeSequence])
  @@index([recipientDeviceId, updatedAt])
  @@index([recipientUserId, status])
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  familyId  String
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ipAddress String?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([familyId])
}

model SocketTicket {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  deviceId    String    @db.Uuid
  sessionId   String    @db.Uuid
  tokenHash   String    @unique
  expiresAt   DateTime
  consumedAt  DateTime?
  consumedBy  String?
  createdAt   DateTime  @default(now())

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([userId, deviceId, expiresAt])
}

model BackupBlob {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @unique @db.Uuid
  bucketKey  String
  sha256     String
  sizeBytes  Int
  version    Int
  uploadedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Otp {
  id        String    @id @default(uuid()) @db.Uuid
  phoneHash String
  code      String
  status    OtpStatus @default(UNUSED)
  attempts  Int       @default(0)
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([phoneHash, status, expiresAt])
  @@index([phoneHash, status, createdAt])
}

model SmsReport {
  id        String       @id @default(uuid()) @db.Uuid
  phoneHash String
  type      SmsType
  provider  SmsProvider
  success   Boolean
  error     String?
  createdAt DateTime     @default(now())

  @@index([phoneHash, createdAt])
}

model Group {
  id                 String         @id @default(uuid()) @db.Uuid
  encryptedMetadata  Json           // Encrypted Group Name & Photo
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  members            GroupMember[]
  messages           Message[]
}

model GroupMember {
  groupId   String   @db.Uuid
  userId    String   @db.Uuid
  role      String   @default("MEMBER") // ADMIN, MEMBER
  joinedAt  DateTime @default(now())

  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@index([userId])
}

model UnreadCounter {
  userId     String   @db.Uuid
  threadType String
  threadId   String   @db.Uuid
  count      Int      @default(0)
  updatedAt  DateTime @updatedAt

  // threadId is polymorphic (direct thread or group) so it stays app-enforced,
  // but the owning user now has referential integrity + cascade cleanup.
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, threadType, threadId])
  @@index([userId])
}

model HiddenMessage {
  userId    String   @db.Uuid
  messageId String   @db.Uuid
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@id([userId, messageId])
}

model PinnedMessage {
  id             String   @id @default(uuid()) @db.Uuid
  // threadType/threadId are polymorphic (direct thread or group), so they stay
  // app-enforced — same pattern as UnreadCounter. The message FK gives cascade
  // cleanup when a message is hard-deleted.
  threadType     String
  threadId       String   @db.Uuid
  messageId      String   @db.Uuid
  pinnedByUserId String   @db.Uuid
  pinnedAt       DateTime @default(now())

  message  Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  pinnedBy User    @relation(fields: [pinnedByUserId], references: [id], onDelete: Cascade)

  @@unique([threadType, threadId, messageId])
  @@index([threadType, threadId, pinnedAt])
  @@index([messageId])
  @@index([pinnedByUserId])
}

model MessageReaction {
  id        String   @id @default(uuid()) @db.Uuid
  messageId String   @db.Uuid
  userId    String   @db.Uuid
  emoji     String   @db.VarChar(16)
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, messageId])
  @@index([messageId])
}

model Report {
  id              String           @id @default(uuid()) @db.Uuid
  reporterUserId  String           @db.Uuid
  messageId       String           @db.Uuid
  reason          ReportReason
  freeText        String?
  status          ReportStatus     @default(OPEN)
  resolution      ReportResolution?
  reviewedByUserId String?         @db.Uuid
  reviewedAt      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  reporter User    @relation("ReportFiler", fields: [reporterUserId], references: [id], onDelete: Cascade)
  message  Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([reporterUserId, messageId])
  @@index([status, createdAt])
  @@index([messageId])
  @@index([reporterUserId, createdAt])
  @@index([reviewedByUserId])
}

model UserSuspension {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @db.Uuid
  suspendedByUserId String    @db.Uuid
  reason            String
  suspendedAt       DateTime  @default(now())
  expiresAt         DateTime?
  revokedAt         DateTime?
  revokedByUserId   String?   @db.Uuid
  revokeReason      String?

  user            User  @relation("SuspensionTarget", fields: [userId], references: [id], onDelete: Cascade)
  suspendedBy     User  @relation("SuspensionActor",  fields: [suspendedByUserId], references: [id], onDelete: Restrict)
  revokedBy       User? @relation("SuspensionRevoker", fields: [revokedByUserId], references: [id], onDelete: SetNull)

  @@index([userId, revokedAt])
  @@index([suspendedByUserId])
  @@index([expiresAt])
}

model AdminAuditLog {
  id           String              @id @default(uuid()) @db.Uuid
  actorUserId  String?             @db.Uuid
  action       AdminAuditAction
  targetType   AdminAuditTargetType
  targetId     String              @db.Uuid
  reason       String?
  metadata     Json?
  createdAt    DateTime            @default(now())

  @@index([actorUserId, createdAt])
  @@index([targetType, targetId])
  @@index([action, createdAt])
  @@index([createdAt])
}

// One row per call attempt (1:1 WebRTC over the realtime gateway). Signaling
// payloads (SDP/ICE) are relayed live and never persisted — this is metadata
// only, mirroring the E2EE posture of messages.
model CallLog {
  id         String     @id @default(uuid()) @db.Uuid
  callerId   String     @db.Uuid
  calleeId   String     @db.Uuid
  type       CallType
  status     CallStatus @default(RINGING)
  startedAt  DateTime   @default(now())
  answeredAt DateTime?
  endedAt    DateTime?
  endReason  String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  caller User @relation("CallsMade", fields: [callerId], references: [id], onDelete: Cascade)
  callee User @relation("CallsReceived", fields: [calleeId], references: [id], onDelete: Cascade)

  @@index([callerId, startedAt])
  @@index([calleeId, startedAt])
  @@index([calleeId, status, startedAt])
}

// Server-side contact book (Telegram-style). The owner uploads salted phone
// hashes; contactUserId is resolved server-side when that hash belongs to a
// registered user (and re-resolved on sync as people join). The display label
// is an opaque client-encrypted blob — the server never sees contact names,
// matching the encryptedProfile pattern.
model Contact {
  id             String   @id @default(uuid()) @db.Uuid
  ownerId        String   @db.Uuid
  phoneHash      String
  contactUserId  String?  @db.Uuid
  encryptedLabel Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  owner       User  @relation("OwnedContacts", fields: [ownerId], references: [id], onDelete: Cascade)
  contactUser User? @relation("ContactTarget", fields: [contactUserId], references: [id], onDelete: SetNull)

  @@unique([ownerId, phoneHash])
  @@index([contactUserId])
  @@index([phoneHash])
}

// Telegram-style chat folders. Folder names are plaintext (pure UX metadata,
// no message content). threadType/threadId on FolderThread are polymorphic
// (direct thread or group) — same app-enforced pattern as UnreadCounter.
model Folder {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  name      String   @db.VarChar(64)
  emoji     String?  @db.VarChar(16)
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  threads FolderThread[]

  @@unique([userId, name])
  @@index([userId, position])
}

model FolderThread {
  id         String   @id @default(uuid()) @db.Uuid
  folderId   String   @db.Uuid
  threadType String
  threadId   String   @db.Uuid
  createdAt  DateTime @default(now())

  folder Folder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@unique([folderId, threadType, threadId])
  @@index([threadType, threadId])
}

model DailyMetric {
  id        String           @id @default(uuid()) @db.Uuid
  date      DateTime         @db.Date
  kind      DailyMetricKind
  dimension String?
  value     Int
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([date, kind, dimension])
  @@index([kind, date])
}
