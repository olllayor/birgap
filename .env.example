NODE_ENV=development
PORT=3000
APP_ORIGIN=http://localhost:3000

DATABASE_URL=postgresql://birgap:birgap@localhost:5432/birgap?schema=public&connection_limit=10
REDIS_URL=redis://:birgap-dev@localhost:6379

JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_ACCESS_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
WEBSOCKET_TICKET_TTL_SECONDS=60

PHONE_HASH_PEPPER=replace-with-at-least-16-characters
OTP_MODE=mock
OTP_MOCK_CODE=000000
OTP_TTL_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=120
OTP_MAX_ATTEMPTS=5
OTP_LOCKOUT_SECONDS=900

SMS_SAYQAL_URL=https://sayqal.uz/api
SMS_SAYQAL_SECRET=your_secret_key
SMS_SAYQAL_USERNAME=your_username

MAX_ACTIVE_DEVICES=3
SIGNED_PREKEY_ROTATION_DAYS=7

PUSH_PROVIDER=logger
FCM_SERVICE_ACCOUNT_JSON=

R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=birgap-backups
R2_PRESIGNED_PUT_TTL_SECONDS=900
R2_PRESIGNED_GET_TTL_SECONDS=300

MEDIA_MAX_ATTACHMENTS_PER_MESSAGE=10
MEDIA_PENDING_TIMEOUT_HOURS=24

ADMIN_PHONE_HASHES=
SUSPENSION_APPEAL_URL=https://example.com/appeal
REPORTS_DAILY_LIMIT=50
REPORTS_COLLUSION_THRESHOLD=10
REPORTS_COLLUSION_WINDOW_HOURS=1
REPORTS_PER_IP_PER_MINUTE=10
REPORT_RETENTION_DAYS=365
DAILY_METRICS_RETENTION_DAYS=365
# Number of trusted reverse-proxy hops. Set to 1 behind a single load balancer
# (Railway, Fly, Render, Cloud Run). 0 (default) means do NOT trust X-Forwarded-For.
TRUST_PROXY_HOPS=0
